ax.set_ylabel('Y (normalized)', fontsize=12)
ax.set_xlim(0, scale)
ax.set_ylim(scale, 0)  # Invert Y axis for image coordinates
ax.set_aspect('equal')
ax.grid(True, alpha=0.3)
ax.set_facecolor('#f9f9f9')
plt.show()
