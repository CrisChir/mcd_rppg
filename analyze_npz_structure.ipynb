    'estimated_heart_rate': float(avg_heart_rate) if avg_heart_rate is not None else None,
    'heart_rate_std': float(std_heart_rate) if std_heart_rate is not None else None,
    'metadata_pulse': float(metadata.get('vital_pulse', 'N/A')),
    'num_rois': len(roi_names),
    'roi_names': roi_names,
    'correlations': {k: float(v) for k, v in correlations.items()},
    'timestamp': str(np.datetime64('now')),
}

# Save summary to JSON
import json
summary_file = selected_file.with_suffix('.analysis.json')
with open(summary_file, 'w') as f:
    json.dump(analysis_summary, f, indent=2)

print(f"\nAnalysis summary saved to: {summary_file}")
```

## Interactive Widget (for Jupyter)

```python
# If running in Jupyter, create interactive widgets
try:
    from ipywidgets import interact, IntSlider, Dropdown
    
    # Function to display specific frame
    def show_frame(frame_idx=0, roi_name=roi_names[0]):
        if frame_idx >= data[roi_name].shape[0]:
            frame_idx = 0
        
        frame = data[roi_name][frame_idx]
        ppg_value = ppg_values[frame_idx]
        
        fig, axes = plt.subplots(1, 4, figsize=(16, 4))
        fig.suptitle(f'Frame {frame_idx} | PPG: {ppg_value:.2f} | ROI: {roi_name}', fontsize=14)
        
        # RGB channels
        for channel, color, title in zip(range(3), ['red', 'green', 'blue'], ['R', 'G', 'B']):
            axes[channel].imshow(frame[:, :, channel], cmap='gray')
            axes[channel].set_title(title, fontsize=12)
            axes[channel].axis('off')
        
        # Combined RGB
        rgb_frame = frame.astype(np.float32)
        if rgb_frame.max() > 1:
            rgb_frame = rgb_frame / 255.0
        axes[3].imshow(rgb_frame)
        axes[3].set_title('RGB', fontsize=12)
        axes[3].axis('off')
        
        plt.tight_layout()
        plt.show()
    
    # Create interactive widget
    if roi_names:
        interact(
            show_frame,
            frame_idx=IntSlider(min=0, max=len(ppg_values)-1, step=1, value=0),
            roi_name=Dropdown(options=roi_names, value=roi_names[0])
        )
except ImportError:
    print("ipywidgets not available. Install with: pip install ipywidgets")
```

