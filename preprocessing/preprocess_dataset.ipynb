## 2. Load Dataset

### Option A: Load from Local Directory

If you have the dataset downloaded locally:

```python
def load_local_dataset(dataset_path: str, limit: int = None) -> List[Dict[str, Any]]:
    """
    Load dataset from local directory structure.
    
    Expected structure:
    dataset_path/
        video/
            subject_001/
                rest/
                    camera_1.avi
                    camera_2.avi
                    camera_3.avi
                exercise/
                    camera_1.avi
                    camera_2.avi
                    camera_3.avi
            subject_002/
                ...
        ppg/
            subject_001/
                rest_camera_1.npy
                rest_camera_2.npy
                ...
        metadata/
            subjects.csv
            biomarkers.csv
    """
    samples = []
    
    # Find all video files
    video_dir = os.path.join(dataset_path, 'video')
    if not os.path.exists(video_dir):
        video_dir = dataset_path  # Try root directory
    
    video_files = []
    for root, dirs, files in os.walk(video_dir):
        for file in files:
            if file.endswith('.avi') or file.endswith('.mp4'):
                video_files.append(os.path.join(root, file))
    
    print(f"Found {len(video_files)} video files")
    
    # Limit for testing
    if limit:
        video_files = video_files[:limit]
    
    # Create samples
    for video_file in video_files:
        sample = {
            'video_file': video_file,
            'subject_id': Path(video_file).parts[-3] if len(Path(video_file).parts) >= 3 else 'unknown',
            'condition': Path(video_file).parts[-2] if len(Path(video_file).parts) >= 2 else 'unknown',
            'camera_id': extract_camera_id(video_file),
            'video': None,
            'ppg': None,
            'ppg_file': find_ppg_file(video_file, dataset_path)
        }
        samples.append(sample)
    
    return samples

def extract_camera_id(video_file: str) -> int:
    """Extract camera ID from video filename."""
    filename = os.path.basename(video_file)
    if 'camera_1' in filename or 'cam_1' in filename:
        return 1
    elif 'camera_2' in filename or 'cam_2' in filename:
        return 2
    elif 'camera_3' in filename or 'cam_3' in filename:
        return 3
    return 1  # Default

def find_ppg_file(video_file: str, dataset_path: str) -> Optional[str]:
    """Find corresponding PPG file for a video."""
    # Extract subject, condition, camera from video path
    parts = Path(video_file).parts
    subject = parts[-3] if len(parts) >= 3 else None
    condition = parts[-2] if len(parts) >= 2 else None
    camera = extract_camera_id(video_file)
    
    if not subject:
        return None
    
    # Try different naming conventions
    ppg_dir = os.path.join(dataset_path, 'ppg', subject)
    if os.path.exists(ppg_dir):
        # Try: condition_camera_X.npy
        ppg_file = os.path.join(ppg_dir, f"{condition}_camera_{camera}.npy")
        if os.path.exists(ppg_file):
            return ppg_file
        
        # Try: camera_X.npy
        ppg_file = os.path.join(ppg_dir, f"camera_{camera}.npy")
        if os.path.exists(ppg_file):
            return ppg_file
    
    return None

# Load dataset
print("Loading dataset...")
samples = load_local_dataset(config.dataset_path, limit=10)  # Limit to 10 for testing
print(f"Loaded {len(samples)} samples")

# Display sample information
if samples:
    print("\nSample information:")
    for i, sample in enumerate(samples[:3]):
        print(f"  {i+1}. {sample['video_file']}")
        print(f"     Subject: {sample['subject_id']}, Condition: {sample['condition']}, Camera: {sample['camera_id']}")
        print(f"     PPG file: {sample['ppg_file']}")
