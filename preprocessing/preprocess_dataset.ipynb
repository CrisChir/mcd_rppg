    processed_samples.append(result)
    
    if result['success']:
        print(f"  ✅ Sample {i+1}: {result['video_file']} - {len(result['video_chunks'])} chunks")
    else:
        print(f"  ❌ Sample {i+1}: {result['video_file']} - Error: {result['error']}")

# Count successes and failures
success_count = sum(1 for r in processed_samples if r['success'])
failure_count = len(processed_samples) - success_count

print(f"\n✅ Processing complete!")
print(f"   Success: {success_count}/{len(processed_samples)}")
print(f"   Failed: {failure_count}/{len(processed_samples)}")
