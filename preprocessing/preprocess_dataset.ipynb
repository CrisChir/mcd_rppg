```python
def process_single_video(
    video_path: str,
    output_path: str,
    ppg_path: str = None,
    config: PreprocessingConfig = None
) -> Dict[str, Any]:
    """
    Process a single video file and save results.
    
    Args:
        video_path: Path to video file
        output_path: Path to save processed data
        ppg_path: Optional path to PPG file
        config: Preprocessing configuration
    
    Returns:
        Dictionary with paths to saved files
    """
    if config is None:
        config = PreprocessingConfig()
    
    # Create sample
    sample = {
        'video_file': video_path,
        'ppg_file': ppg_path,
        'subject_id': Path(video_path).stem,
        'condition': 'unknown',
        'camera_id': 1
    }
    
    # Initialize detector
    detector = initialize_mediapipe(config)
    
    # Process sample
    result = process_sample(sample, detector, config)
    
    if result['success']:
        # Save results
        os.makedirs(output_path, exist_ok=True)
        
        if result['video_chunks']:
            np.save(os.path.join(output_path, 'video_chunks.npy'), np.array(result['video_chunks']))
        if result['ppg_chunks']:
            np.save(os.path.join(output_path, 'ppg_chunks.npy'), np.array(result['ppg_chunks']))
        if result['landmarks']:
            np.save(os.path.join(output_path, 'landmarks.npy'), np.array(result['landmarks']))
        
        # Save metadata
        metadata = {
            'video_file': video_path,
            'subject_id': sample['subject_id'],
            'num_chunks': len(result['video_chunks']),
            'original_frames': result['original_frames'],
            'processed_frames': result['processed_frames']
        }
        pd.DataFrame([metadata]).to_csv(os.path.join(output_path, 'metadata.csv'), index=False)
        
        return {
            'success': True,
            'output_path': output_path,
            'num_chunks': len(result['video_chunks'])
        }
    else:
        return {
            'success': False,
            'error': result['error']
        }

