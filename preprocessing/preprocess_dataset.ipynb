## 6. Save Preprocessed Data

### Save to Disk

```python
def save_preprocessed_data(
    processed_samples: List[Dict[str, Any]],
    output_path: str,
    config: PreprocessingConfig
) -> Dict[str, Any]:
    """
    Save preprocessed data to disk.
    
    Returns:
        Dictionary with paths to saved files
    """
    os.makedirs(output_path, exist_ok=True)
    
    saved_files = {}
    
    # Collect all chunks
    all_video_chunks = []
    all_ppg_chunks = []
    all_metadata = []
    all_landmarks = []
    all_rois = {roi: [] for roi in config.rois}
    
    for i, sample in enumerate(processed_samples):
        if not sample['success']:
            continue
        
        # Add chunks
        all_video_chunks.extend(sample['video_chunks'])
        all_ppg_chunks.extend(sample['ppg_chunks'])
        all_landmarks.extend(sample['landmarks'])
        
        # Add metadata for each chunk
        num_chunks = len(sample['video_chunks'])
        for j in range(num_chunks):
            metadata = {
                'sample_idx': i,
                'chunk_idx': j,
                'subject_id': sample['subject_id'],
                'condition': sample['condition'],
                'camera_id': sample['camera_id'],
                'original_frames': sample['original_frames'],
                'processed_frames': sample['processed_frames'],
                'video_file': sample['video_file']
            }
            all_metadata.append(metadata)
        
        # Add ROIs
        for roi_name in config.rois:
            all_rois[roi_name].extend(sample['rois'][roi_name])
    
    # Save video chunks
    if all_video_chunks:
        video_chunks_path = os.path.join(output_path, 'video_chunks.npy')
        np.save(video_chunks_path, np.array(all_video_chunks))
        saved_files['video_chunks'] = video_chunks_path
        print(f"Saved video chunks: {video_chunks_path} (shape: {np.array(all_video_chunks).shape})")
    
    # Save PPG chunks
    if all_ppg_chunks:
        ppg_chunks_path = os.path.join(output_path, 'ppg_chunks.npy')
        np.save(ppg_chunks_path, np.array(all_ppg_chunks))
        saved_files['ppg_chunks'] = ppg_chunks_path
        print(f"Saved PPG chunks: {ppg_chunks_path} (shape: {np.array(all_ppg_chunks).shape})")
    
    # Save landmarks
    if all_landmarks:
        landmarks_path = os.path.join(output_path, 'landmarks.npy')
        np.save(landmarks_path, np.array(all_landmarks))
        saved_files['landmarks'] = landmarks_path
        print(f"Saved landmarks: {landmarks_path} (shape: {np.array(all_landmarks).shape})")
    
    # Save ROIs
    for roi_name in config.rois:
        if all_rois[roi_name]:
            roi_path = os.path.join(output_path, f'{roi_name}_chunks.npy')
            np.save(roi_path, np.array(all_rois[roi_name]))
            saved_files[roi_name] = roi_path
            print(f"Saved {roi_name} chunks: {roi_path} (shape: {np.array(all_rois[roi_name]).shape})")
    
    # Save metadata
    metadata_path = os.path.join(output_path, 'metadata.csv')
    metadata_df = pd.DataFrame(all_metadata)
    metadata_df.to_csv(metadata_path, index=False)
    saved_files['metadata'] = metadata_path
    print(f"Saved metadata: {metadata_path} ({len(metadata_df)} entries)")
    
    # Create train/val/test splits
    subject_ids = metadata_df['subject_id'].unique()
    train_subjects, test_subjects = train_test_split(
        subject_ids,
        test_size=config.test_ratio + config.val_ratio,
        random_state=config.random_state
    )
    val_subjects, test_subjects = train_test_split(
        test_subjects,
        test_size=config.test_ratio / (config.test_ratio + config.val_ratio),
        random_state=config.random_state
    )
    
    # Save splits
    for split_name, subjects in [('train', train_subjects), ('val', val_subjects), ('test', test_subjects)]:
        split_path = os.path.join(output_path, f'{split_name}_subjects.txt')
        with open(split_path, 'w') as f:
            for subject in subjects:
                f.write(f'{subject}\n')
        saved_files[split_name] = split_path
        print(f"Saved {split_name} split: {split_path} ({len(subjects)} subjects)")
    
    return saved_files

# Save preprocessed data
print("\nSaving preprocessed data...")
saved_files = save_preprocessed_data(processed_samples, config.output_path, config)

print("\n✅ All data saved successfully!")
for key, path in saved_files.items():
    if os.path.exists(path):
        size = os.path.getsize(path) / (1024 * 1024)  # MB
        print(f"   {key}: {path} ({size:.2f} MB)")
