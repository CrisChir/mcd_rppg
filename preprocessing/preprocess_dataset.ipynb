### Example 2: Process Multiple Videos in Batch

```python
def process_batch(
    video_paths: List[str],
    output_path: str,
    ppg_paths: List[str] = None,
    config: PreprocessingConfig = None,
    batch_size: int = 10
) -> Dict[str, Any]:
    """
    Process multiple videos in batches.
    
    Args:
        video_paths: List of video file paths
        output_path: Path to save processed data
        ppg_paths: Optional list of PPG file paths
        config: Preprocessing configuration
        batch_size: Number of videos to process at once
    
    Returns:
        Dictionary with processing statistics
    """
    if config is None:
        config = PreprocessingConfig()
    
    if ppg_paths is None:
        ppg_paths = [None] * len(video_paths)
    
    # Initialize detector
    detector = initialize_mediapipe(config)
    
    # Create samples
    samples = []
    for i, (video_path, ppg_path) in enumerate(zip(video_paths, ppg_paths)):
        sample = {
            'video_file': video_path,
            'ppg_file': ppg_path,
            'subject_id': f"subject_{i:03d}",
            'condition': 'unknown',
            'camera_id': (i % 3) + 1
        }
        samples.append(sample)
    
    # Process in batches
    all_results = []
    for i in tqdm(range(0, len(samples), batch_size), desc="Processing batches"):
        batch = samples[i:i+batch_size]
        batch_results = []
        
        for sample in batch:
            result = process_sample(sample, detector, config)
            batch_results.append(result)
        
        all_results.append(batch_results)
    
    # Save all results
    os.makedirs(output_path, exist_ok=True)
    save_preprocessed_data([r for batch in all_results for r in batch], output_path, config)
    
    # Return statistics
    success_count = sum(1 for r in all_results for r in batch if r['success'])
    total_count = len(samples)
    
    return {
        'total': total_count,
        'success': success_count,
        'failure': total_count - success_count,
        'output_path': output_path
    }

# Example usage:
# video_paths = [
#     "/path/to/video1.avi",
#     "/path/to/video2.avi",
#     "/path/to/video3.avi"
# ]
