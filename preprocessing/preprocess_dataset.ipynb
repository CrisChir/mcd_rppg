def verify_output(output_path: str, saved_files: Dict[str, Any]) -> bool:
    """Verify that all output files are valid."""
    print("Verifying output...")
    
    all_valid = True
    
    # Check video chunks
    if 'video_chunks' in saved_files:
        video_chunks = np.load(saved_files['video_chunks'])
        print(f"✅ Video chunks: shape={video_chunks.shape}, dtype={video_chunks.dtype}")
    else:
        print("❌ Video chunks not found")
        all_valid = False
    
    # Check PPG chunks
    if 'ppg_chunks' in saved_files:
        ppg_chunks = np.load(saved_files['ppg_chunks'])
        print(f"✅ PPG chunks: shape={ppg_chunks.shape}, dtype={ppg_chunks.dtype}")
    else:
        print("❌ PPG chunks not found")
        all_valid = False
    
    # Check landmarks
    if 'landmarks' in saved_files:
        landmarks = np.load(saved_files['landmarks'])
        print(f"✅ Landmarks: shape={landmarks.shape}, dtype={landmarks.dtype}")
    else:
        print("❌ Landmarks not found")
        all_valid = False
    
    # Check metadata
    if 'metadata' in saved_files:
        metadata = pd.read_csv(saved_files['metadata'])
        print(f"✅ Metadata: {len(metadata)} entries")
        print(f"   Columns: {list(metadata.columns)}")
    else:
        print("❌ Metadata not found")
        all_valid = False
    
    # Check ROIs
    for roi_name in config.rois:
        if roi_name in saved_files:
            roi_chunks = np.load(saved_files[roi_name])
            print(f"✅ {roi_name} chunks: shape={roi_chunks.shape}")
        else:
            print(f"❌ {roi_name} chunks not found")
            all_valid = False
    
    # Check splits
    for split_name in ['train', 'val', 'test']:
        if split_name in saved_files:
            with open(saved_files[split_name], 'r') as f:
                subjects = f.read().strip().split('\n')
            print(f"✅ {split_name} split: {len(subjects)} subjects")
        else:
            print(f"❌ {split_name} split not found")
            all_valid = False
    
    return all_valid

