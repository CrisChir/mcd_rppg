    "        chunks = create_chunks(n_frames, CHUNK_SIZE, OVERLAP_SIZE)\n",
    "        if chunks:\n",
    "            start, end, chunk_idx = chunks[0]\n",
    "            print(f'Processing first chunk: frames {start}-{end}')\n",
    "            \n",
    "            # Prepare metadata\n",
    "            meta_data = {\n",
    "                'subject_id': video_row['patient_id'],\n",
    "                'condition': video_row['condition'],\n",
