   "source": [
    "## 5. ROI Extraction and Bounding Box Calculation"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "roi_extraction",
   "metadata": {},
   "outputs": [],
   "source": [
    "def extract_roi_bbox(landmarks, roi_indices, frame_shape, box_size=(24, 24)):\n",
    "    \"\"\"\n",
    "    Extract bounding box for a specific ROI.\n",
    "    \n",
    "    Args:\n",
    "        landmarks: Landmarks array of shape (468, 2)\n",
    "        roi_indices: List of landmark indices for the ROI\n",
    "        frame_shape: Shape of the frame (H, W)\n",
    "        box_size: Fixed size of the bounding box (W, H)\n",
    "    \n",
    "    Returns:\n",
    "        Bounding box as (x, y, w, h) where (x, y) is the top-left corner\n",
    "    \"\"\"\n",
    "    # Get ROI landmarks\n",
    "    valid_indices = [i for i in roi_indices if i < len(landmarks)]\n",
    "    if not valid_indices:\n",
    "        return (0, 0, box_size[0], box_size[1])\n",
    "    \n",
    "    roi_points = landmarks[valid_indices]\n",
    "    \n",
    "    # Calculate center\n",
    "    center_x = int(np.mean(roi_points[:, 0]))\n",
    "    center_y = int(np.mean(roi_points[:, 1]))\n",
    "    \n",
    "    # Calculate bounding box (centered on ROI)\n",
    "    box_w, box_h = box_size\n",
    "    x = max(0, center_x - box_w // 2)\n",
    "    y = max(0, center_y - box_h // 2)\n",
    "    \n",
    "    # Ensure box fits within frame\n",
    "    x = min(x, frame_shape[1] - box_w)\n",
    "    y = min(y, frame_shape[0] - box_h)\n",
    "    \n",
    "    return (x, y, box_w, box_h)\n",
    "\n",
    "def extract_roi_region(frame, bbox):\n",
    "    \"\"\"Extract ROI region from a frame given bounding box.\"\"\"\n",
    "    x, y, w, h = bbox\n",
    "    return frame[y:y+h, x:x+w]\n",
    "\n",
    "def extract_all_rois_for_frame(frame, landmarks, rois_dict, box_size=(24, 24)):\n",
    "    \"\"\"Extract all ROIs for a single frame.\"\"\"\n",
    "    frame_shape = frame.shape[:2]\n",
    "    roi_data = {}\n",
    "    \n",
    "    for roi_name, roi_indices in rois_dict.items():\n",
    "        bbox = extract_roi_bbox(landmarks, roi_indices, frame_shape, box_size)\n",
    "        roi_region = extract_roi_region(frame, bbox)\n",
    "        roi_data[roi_name] = roi_region\n",
    "    \n",
    "    return roi_data\n",
    "\n",
    "# Test ROI extraction\n",
    "if MEDIAPIPE_AVAILABLE:\n",
    "    print('=' * 80)\n",
    "    print('ROI EXTRACTION TEST')\n",
    "    print('=' * 80)\n",
    "    \n",
    "    # Use the same sample video as before\n",
    "    sample_video = meta_df.dropna(subset=['video_full']).iloc[0]\n",
    "    video_path = sample_video['video_full']\n",
    "    \n",
    "    if os.path.exists(video_path):\n",
    "        try:\n",
    "            reader = imageio.get_reader(video_path, 'ffmpeg')\n",
    "            frame = reader.get_next_data()\n",
    "            reader.close()\n",
    "            \n",
    "            # Get landmarks\n",
    "            detector.reset()\n",
    "            lms = detector.detect_landmarks(frame)\n",
    "            \n",
    "            if lms is not None:\n",
    "                print(f'Frame shape: {frame.shape}')\n",
    "                print(f'Landmarks detected: {len(lms)}')\n",
    "                \n",
    "                # Extract all ROIs\n",
    "                roi_data = extract_all_rois_for_frame(frame, lms, ROIS, ROI_BOX_SIZE)\n",
    "                \n",
    "                # Display ROI information\n",
    "                print('\\nROI Information:')\n",
    "                for roi_name, roi_region in roi_data.items():\n",
    "                    print(f'  {roi_name}: {roi_region.shape}')\n",
    "                \n",
    "                # Visualize all ROIs\n",
    "                n_rois = len(roi_data)\n",
    "                cols = 4\n",
    "                rows = (n_rois + cols - 1) // cols\n",
    "                \n",
    "                fig, axes = plt.subplots(rows, cols, figsize=(20, 5 * rows))\n",
    "                axes = axes.flatten() if isinstance(axes, np.ndarray) else [axes]\n",
    "                \n",
    "                for idx, (roi_name, roi_region) in enumerate(roi_data.items()):\n",
    "                    axes[idx].imshow(roi_region)\n",
    "                    axes[idx].set_title(f'{roi_name} ({roi_region.shape[1]}x{roi_region.shape[0]})')\n",
    "                    axes[idx].axis('off')\n",
    "                \n",
    "                # Hide unused subplots\n",
    "                for idx in range(len(roi_data), len(axes)):\n",
    "                    axes[idx].axis('off')\n",
    "                \n",
    "                plt.suptitle('Extracted ROIs (24x24 boxes)')\n",
    "                plt.tight_layout()\n",
    "                plt.show()\n",
    "            else:\n",
    "                print('No landmarks detected')\n",
    "                \n",
    "        except Exception as e:\n",
    "            print(f'Error: {e}')\n",
    "    else:\n",
    "        print(f'Video not found: {video_path}')\n",
    "else:\n",
    "    print('Skipping ROI extraction test - MediaPipe not available')"
   ]
