    "                    if valid_indices:\n",
    "                        roi_points = lms[valid_indices]\n",
    "                        x_coords = roi_points[:, 0]\n",
    "                        y_coords = roi_points[:, 1]\n",
    "                        center_x = int(np.mean(x_coords))\n",
    "                        center_y = int(np.mean(y_coords))\n",
