    "                            linewidth=2, edgecolor='cyan', facecolor='none')\n",
    "                        ax.add_patch(rect)\n",
    "                        ax.text(center_x - box_w//2, center_y - box_h//2 - 10, roi_name,\n",
    "                               color='cyan', fontsize=8,\n",
    "                               bbox=dict(facecolor='cyan', alpha=0.5))\n",
    "                \n",
    "                ax.set_title('ROI Bounding Boxes (24x24)')\n",
    "                ax.axis('off')\n",
