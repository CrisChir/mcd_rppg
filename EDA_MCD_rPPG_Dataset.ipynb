## 🫀 6. ECG Signal Analysis

```python
print("\n" + "=" * 80)
print("🫀 ECG SIGNAL ANALYSIS")
print("=" * 80)

# Check if we can load some ECG data
print("📂 ECG Directory Structure:")
if os.path.exists(ECG_PATH):
    ecg_files = []
    for root, dirs, files in os.walk(ECG_PATH):
        for file in files[:10]:  # Show first 10 files
            ecg_files.append(os.path.join(root, file))
    
    print(f"✅ Found {len(ecg_files)} ECG files (showing first 10):")
    for file in ecg_files[:10]:
        size = os.path.getsize(file) / 1024 / 1024
        print(f"  {file} ({size:.2f} MB)")
    
    # Try to load a sample ECG signal
    if ecg_files:
        try:
            sample_ecg = np.load(ecg_files[0])
            print(f"\n📊 Sample ECG Signal:")
            print(f"  Shape: {sample_ecg.shape}")
            print(f"  Dtype: {sample_ecg.dtype}")
            print(f"  Min: {sample_ecg.min():.2f}")
            print(f"  Max: {sample_ecg.max():.2f}")
            print(f"  Mean: {sample_ecg.mean():.2f}")
            print(f"  Std: {sample_ecg.std():.2f}")
            
            # Plot sample ECG
            plt.figure(figsize=(15, 4))
            plt.plot(sample_ecg[:1000], color='green', linewidth=1)
            plt.title(f'ECG Signal Sample (First 1000 samples)')
            plt.xlabel('Sample Index')
            plt.ylabel('ECG Value')
            plt.grid(True, alpha=0.3)
            plt.show()
            
            # Plot ECG in time domain (assuming 100 Hz sampling)
            time = np.arange(len(sample_ecg)) / 100.0  # Convert to seconds
            plt.figure(figsize=(15, 4))
            plt.plot(time[:10], sample_ecg[:1000], color='green', linewidth=1)
            plt.title(f'ECG Signal (First 10 seconds)')
            plt.xlabel('Time (seconds)')
            plt.ylabel('ECG Value')
            plt.grid(True, alpha=0.3)
            plt.show()
            
        except Exception as e:
            print(f"❌ Error loading ECG: {e}")
else:
    print(f"❌ ECG directory not found at: {ECG_PATH}")
```

