# Load the database
if os.path.exists(DB_PATH):
    df_db = pd.read_csv(DB_PATH)
    print(f"✅ Database loaded successfully!")
    print(f"📊 Shape: {df_db.shape}")
    print(f"📋 Columns: {list(df_db.columns)}")
    
    # Display basic info
    print("\n📈 Database Info:")
    display(df_db.info())
    
    # Display first few rows
    print("\n👀 First 5 rows:")
    display(df_db.head())
    
    # Basic statistics
    print("\n📊 Basic Statistics:")
    display(df_db.describe())
    
    # Check for missing values
    print("\n❌ Missing Values:")
    missing = df_db.isnull().sum()
    missing_pct = (missing / len(df_db)) * 100
    missing_df = pd.DataFrame({'Missing': missing, 'Percentage': missing_pct})
    display(missing_df[missing_df['Missing'] > 0].sort_values('Missing', ascending=False))
    
    # Unique values for categorical columns
    print("\n🔍 Unique Values Analysis:")
    for col in df_db.columns:
        if df_db[col].dtype == 'object':
            unique_count = df_db[col].nunique()
            print(f"  {col}: {unique_count} unique values")
            if unique_count <= 10:
                print(f"    Values: {df_db[col].unique()[:10]}")
else:
    print(f"❌ Database file not found at: {DB_PATH}")
