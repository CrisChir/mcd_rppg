## 📁 1. File Structure Analysis

```python
# Analyze directory structure
print("=" * 80)
print("📁 FILE STRUCTURE ANALYSIS")
print("=" * 80)

def analyze_directory(path, name, max_depth=2):
    """Analyze directory structure"""
    print(f"\n📂 {name}: {path}")
    print("-" * 60)
    
    if not os.path.exists(path):
        print(f"⚠️  Directory does not exist!")
        return
    
    total_files = 0
    total_size = 0
    
    for root, dirs, files in os.walk(path):
        level = root.replace(path, '').count(os.sep)
        if level > max_depth:
            continue
        
        indent = ' ' * 2 * level
        print(f'{indent}{os.path.basename(root)}/')
        
        for file in files[:5]:  # Show first 5 files
            file_path = os.path.join(root, file)
            file_size = os.path.getsize(file_path)
            total_files += 1
            total_size += file_size
            print(f'{indent}  {file} ({file_size / 1024 / 1024:.2f} MB)')
        
        if len(files) > 5:
            print(f'{indent}  ... and {len(files) - 5} more files')
            total_files += len(files) - 5
    
    print(f"\n📊 Total: {total_files} files, {total_size / 1024 / 1024 / 1024:.2f} GB")

# Analyze each directory
analyze_directory(VIDEOS_PATH, "VIDEOS")
analyze_directory(PPG_PATH, "PPG SIGNALS")
analyze_directory(PPG_SYNC_PATH, "PPG SYNC")
analyze_directory(ECG_PATH, "ECG SIGNALS")
analyze_directory(METADATA_PATH, "METADATA")
```

## 🗃️ 2. Database Analysis

```python
print("\n" + "=" * 80)
print("🗃️  DATABASE ANALYSIS")
