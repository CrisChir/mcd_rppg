## 🏥 8. Health Biomarkers Analysis

```python
print("\n" + "=" * 80)
print("🏥 HEALTH BIOMARKERS ANALYSIS")
print("=" * 80)

# Check metadata directory for biomarkers
metadata_files = []
if os.path.exists(METADATA_PATH):
    for root, dirs, files in os.walk(METADATA_PATH):
        for file in files:
            metadata_files.append(os.path.join(root, file))
    
    print(f"📂 Metadata files found: {len(metadata_files)}")
    for file in metadata_files[:10]:
        print(f"  {file}")

# Try to load metadata
biomarkers_df = None
subjects_df = None

# Common metadata filenames
metadata_filenames = ['biomarkers.csv', 'subjects.csv', 'metadata.csv', 'vitals.csv']
for filename in metadata_filenames:
    test_path = os.path.join(METADATA_PATH, filename)
    if os.path.exists(test_path):
        try:
            df = pd.read_csv(test_path)
            print(f"\n✅ Loaded {filename}:")
            print(f"  Shape: {df.shape}")
            print(f"  Columns: {list(df.columns)}")
            display(df.head())
            
            if 'biomarker' in filename.lower():
                biomarkers_df = df
            elif 'subject' in filename.lower():
                subjects_df = df
        except Exception as e:
            print(f"❌ Error loading {filename}: {e}")

# If we have patient_id in our main dataframe, we can try to merge
if 'patient_id' in df_db.columns and biomarkers_df is not None:
    # Try to merge with biomarkers
    if 'subject_id' in biomarkers_df.columns:
        biomarkers_df['subject_id'] = biomarkers_df['subject_id'].astype(str)
        df_db['subject_id'] = df_db['patient_id'].astype(str)
        
        merged_df = pd.merge(df_db, biomarkers_df, on='subject_id', how='left')
        print(f"\n✅ Merged dataframe shape: {merged_df.shape}")
        
        # Show biomarker distributions
        biomarker_columns = [col for col in merged_df.columns if col not in df_db.columns]
        print(f"📊 Biomarker columns: {biomarker_columns}")
        
        # Plot biomarker distributions
        if biomarker_columns:
            n_cols = min(3, len(biomarker_columns))
            n_rows = (len(biomarker_columns) + n_cols - 1) // n_cols
            
            plt.figure(figsize=(15, 5 * n_rows))
            for i, col in enumerate(biomarker_columns):
                plt.subplot(n_rows, n_cols, i + 1)
                
                # Check if numeric
                if pd.api.types.is_numeric_dtype(merged_df[col]):
                    plt.hist(merged_df[col].dropna(), bins=30, color='skyblue', edgecolor='black', alpha=0.7)
                    plt.title(f'{col} Distribution')
                    plt.xlabel(col)
                    plt.ylabel('Frequency')
                else:
                    value_counts = merged_df[col].value_counts()
                    value_counts.plot(kind='bar', color='lightcoral')
                    plt.title(f'{col} Distribution')
                    plt.xlabel(col)
                    plt.ylabel('Count')
                    plt.xticks(rotation=45)
            
            plt.tight_layout()
            plt.show()
            
            # Correlation matrix for biomarkers
            numeric_biomarkers = [col for col in biomarker_columns if pd.api.types.is_numeric_dtype(merged_df[col])]
            if len(numeric_biomarkers) > 1:
                corr_matrix = merged_df[numeric_biomarkers].corr()
                
                plt.figure(figsize=(12, 10))
                sns.heatmap(corr_matrix, annot=True, cmap='coolwarm', center=0, vmin=-1, vmax=1)
                plt.title('Biomarker Correlation Matrix')
                plt.show()

