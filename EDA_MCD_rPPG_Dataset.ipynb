## 🎯 3. Subject Demographics and Distribution

```python
print("\n" + "=" * 80)
print("🎯 SUBJECT DEMOGRAPHICS AND DISTRIBUTION")
print("=" * 80)

if os.path.exists(DB_PATH):
    # Extract subject information from file paths
    df_db['subject_id'] = df_db['file'].apply(lambda x: os.path.basename(x).split('__')[1] if '__' in x else 'unknown')
    df_db['condition'] = df_db['file'].apply(lambda x: 'after' if 'after' in x else 'before' if 'before' in x else 'unknown')
    
    print(f"📊 Total unique subjects: {df_db['subject_id'].nunique()}")
    print(f"📊 Total recordings: {len(df_db)}")
    print(f"📊 Recordings per subject: {len(df_db) / df_db['subject_id'].nunique():.1f}")
    
    # Condition distribution
    plt.figure(figsize=(12, 5))
    
    plt.subplot(1, 2, 1)
    condition_counts = df_db['condition'].value_counts()
    condition_counts.plot(kind='bar', color=['skyblue', 'salmon'])
    plt.title('Condition Distribution')
    plt.xlabel('Condition')
    plt.ylabel('Count')
    plt.xticks(rotation=0)
    
    plt.subplot(1, 2, 2)
    subject_counts = df_db['subject_id'].value_counts().value_counts().sort_index()
    subject_counts.plot(kind='bar', color='lightgreen')
    plt.title('Recordings per Subject Distribution')
    plt.xlabel('Number of Recordings')
    plt.ylabel('Number of Subjects')
    
    plt.tight_layout()
    plt.show()
    
    # Fold distribution
    if 'fold' in df_db.columns:
        plt.figure(figsize=(8, 5))
        fold_counts = df_db['fold'].value_counts().sort_index()
        fold_counts.plot(kind='bar', color=['lightblue', 'lightcoral', 'lightgreen'])
        plt.title('Fold Distribution')
        plt.xlabel('Fold')
        plt.ylabel('Count')
        plt.xticks(rotation=0)
        plt.show()
        
        print(f"📊 Fold distribution:")
        for fold, count in fold_counts.items():
            print(f"  Fold {fold}: {count} samples ({count/len(df_db)*100:.1f}%)")
