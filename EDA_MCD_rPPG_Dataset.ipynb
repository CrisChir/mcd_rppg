## 🎯 13. Data Quality Assessment

```python
print("\n" + "=" * 80)
print("🎯 DATA QUALITY ASSESSMENT")
print("=" * 80)

if os.path.exists(DB_PATH):
    # Quality metrics
    print("📊 Data Quality Metrics:")
    
    # Check for outliers
    numeric_cols = ['video_mean', 'video_std', 'ppg_mean', 'ppg_std', 'video_duration', 'face_square']
    
    plt.figure(figsize=(15, 10))
    for i, col in enumerate(numeric_cols):
        plt.subplot(2, 3, i + 1)
        
        # Boxplot to show outliers
        sns.boxplot(x=df_db[col], color='lightblue')
        plt.title(f'{col.replace("_", " ").title()} - Outlier Detection')
        plt.xlabel(col.replace('_', ' ').title())
        
        # Calculate outlier percentage (using IQR method)
        Q1 = df_db[col].quantile(0.25)
        Q3 = df_db[col].quantile(0.75)
        IQR = Q3 - Q1
        lower_bound = Q1 - 1.5 * IQR
        upper_bound = Q3 + 1.5 * IQR
        outliers = ((df_db[col] < lower_bound) | (df_db[col] > upper_bound)).sum()
        outlier_pct = (outliers / len(df_db[col])) * 100
        
        plt.text(0.05, 0.95, f'Outliers: {outlier_pct:.1f}%', 
                transform=plt.gca().transAxes, 
                bbox=dict(facecolor='white', alpha=0.8))
    
    plt.tight_layout()
    plt.show()
    
    # Signal quality assessment
    print("\n📊 Signal Quality Assessment:")
    
    # PPG signal quality (based on range and std)
    df_db['ppg_quality_score'] = (df_db['ppg_std'] / df_db['ppg_std'].max()) * 100
    
    plt.figure(figsize=(12, 5))
    
    plt.subplot(1, 2, 1)
    plt.hist(df_db['ppg_quality_score'], bins=50, color='red', edgecolor='black', alpha=0.7)
    plt.title('PPG Quality Score Distribution')
    plt.xlabel('Quality Score')
    plt.ylabel('Frequency')
    plt.axvline(df_db['ppg_quality_score'].mean(), color='black', linestyle='--', label=f'Mean: {df_db["ppg_quality_score"].mean():.1f}')
    plt.legend()
    
    plt.subplot(1, 2, 2)
    plt.scatter(df_db['ppg_std'], df_db['ppg_quality_score'], alpha=0.5, color='red')
    plt.title('PPG Std Dev vs Quality Score')
    plt.xlabel('PPG Std Dev')
    plt.ylabel('Quality Score')
    
    plt.tight_layout()
    plt.show()
    
    # Video quality assessment
    df_db['video_quality_score'] = (df_db['video_std'] / df_db['video_std'].max()) * 100
    
    plt.figure(figsize=(12, 5))
    
    plt.subplot(1, 2, 1)
    plt.hist(df_db['video_quality_score'], bins=50, color='blue', edgecolor='black', alpha=0.7)
    plt.title('Video Quality Score Distribution')
    plt.xlabel('Quality Score')
    plt.ylabel('Frequency')
    plt.axvline(df_db['video_quality_score'].mean(), color='black', linestyle='--', label=f'Mean: {df_db["video_quality_score"].mean():.1f}')
    plt.legend()
    
    plt.subplot(1, 2, 2)
    plt.scatter(df_db['video_std'], df_db['video_quality_score'], alpha=0.5, color='blue')
    plt.title('Video Std Dev vs Quality Score')
    plt.xlabel('Video Std Dev')
    plt.ylabel('Quality Score')
    
    plt.tight_layout()
    plt.show()
