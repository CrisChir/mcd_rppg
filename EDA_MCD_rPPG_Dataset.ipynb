    # Parse video shape
    def parse_shape(shape_str):
        try:
            shape = eval(shape_str)
            return shape[0] if isinstance(shape, tuple) else None
        except:
            return None
    
    video_stats['num_frames'] = video_stats['video_shape'].apply(parse_shape)
    
    display(video_stats.describe())
    
